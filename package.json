{
  "name": "suwappu-flywheel",
  "version": "1.0.0",
  "description": "Self-sustaining multi-strategy DeFi agent — yield rotation, fear-DCA, grid bot, airdrop farming, prediction scout",
  "type": "module",
  "bin": { "suwappu-flywheel": "src/cli.ts", "flywheel-tui": "src/tui.ts" },
  "scripts": {
    "start": "bun run src/cli.ts run --config config.example.json --dry-run",
    "yield": "bun run src/cli.ts yield",
    "dca": "bun run src/cli.ts dca --dry-run",
    "arb": "bun run src/cli.ts arb",
    "predict": "bun run src/cli.ts predict",
    "status": "bun run src/cli.ts status",
    "tui": "bun run src/tui.ts",
    "check": "tsc --noEmit",
    "test": "bun test"
  },
  "dependencies": {
    "@suwappu/sdk": "^0.4.0",
    "commander": "^12.0.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  },
  "engines": { "node": ">=18" },
  "license": "MIT"
}
